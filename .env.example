# Read by `docker compose` (not by the Node apps) for variable substitution
# in docker-compose.yml. PS_JWT_JWK_K must be the base64url encoding of the
# exact same string as JWT_SECRET in apps/api/.env — PowerSync verifies the
# JWTs NestJS issues, so the keys must match byte-for-byte. Regenerate with:
#   node -e "console.log(Buffer.from('<your JWT_SECRET>', 'utf8').toString('base64url'))"
PS_JWT_JWK_K=Y2hhbmdlLW1lLXRvLWEtbG9uZy1yYW5kb20tc3RyaW5n
